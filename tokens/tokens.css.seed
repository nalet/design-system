/* nalet design system — tokens
 *
 * Drop this :root block at the top of any new project. The generated
 * src/styles/tokens.css is built from tokens/tokens.json on top of these
 * values; this seed is the human-readable reference snapshot.
 *
 * Last reviewed: 2026-05-22.
 */

:root {
  /* canvas */
  --bg:          #0B0F19;
  --bg-2:        #0D1117;
  --surface:     #11161F;
  --surface-2:   #161B26;
  --border:      #1F2633;
  --border-2:    #2A3142;

  /* foreground */
  --fg:          #E6E6E6;
  --fg-2:        #C9D1D9;
  --fg-muted:    #AEB8C2;
  --fg-dim:      #6E7787;

  /* brand & signal */
  --cloud-blue:    #58A6FF;  /* chevron, links, primary cta */
  --cloud-cyan:    #00A4DC;  /* cursor, active stroke      */
  --signal-green:  #2EA043;  /* ok / running               */
  --signal-amber:  #F2B233;  /* warn / delayed             */
  --signal-red:    #F85149;  /* error / failed / offline   */

  /* type */
  --ff-ui:   'Inter', system-ui, sans-serif;
  --ff-mono: 'JetBrains Mono', ui-monospace, monospace;

  /* space (4-base) */
  --s-1: 4px;  --s-2: 8px;  --s-3: 12px; --s-4: 16px;
  --s-5: 24px; --s-6: 32px; --s-7: 48px; --s-8: 64px;
}

body {
  background: var(--bg);
  color: var(--fg);
  font-family: var(--ff-ui);
}
