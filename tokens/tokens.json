{
  "$schema": "https://designtokens.org/tr/drafts/format/",
  "$description": "nalet.cloud design tokens. Single source of truth: gitlab.nalet.cloud/standards/design-system/tokens.css.",
  "color": {
    "canvas": {
      "bg":        { "$value": "#0B0F19", "$type": "color", "$description": "Primary background, deepest canvas" },
      "bg-2":      { "$value": "#0D1117", "$type": "color", "$description": "Deeper recesses, terminal blocks" },
      "surface":   { "$value": "#11161F", "$type": "color", "$description": "Cards, panels, raised areas" },
      "surface-2": { "$value": "#161B26", "$type": "color", "$description": "Hover state on surface" },
      "border":    { "$value": "#1F2633", "$type": "color", "$description": "Hairline borders, dividers" },
      "border-2":  { "$value": "#2A3142", "$type": "color", "$description": "Heavier dividers" }
    },
    "foreground": {
      "fg":       { "$value": "#E6E6E6", "$type": "color", "$description": "Primary text, titles" },
      "fg-2":     { "$value": "#C9D1D9", "$type": "color", "$description": "Body text, the n glyph" },
      "fg-muted": { "$value": "#AEB8C2", "$type": "color", "$description": "Labels, meta, captions" },
      "fg-dim":   { "$value": "#6E7787", "$type": "color", "$description": "Helpers, hints, 'off'" }
    },
    "brand": {
      "cloud-blue": { "$value": "#58A6FF", "$type": "color", "$description": "Chevron, links, primary CTA" },
      "cloud-cyan": { "$value": "#00A4DC", "$type": "color", "$description": "Cursor, active stroke" }
    },
    "signal": {
      "green": { "$value": "#2EA043", "$type": "color", "$description": "ok / running / healthy" },
      "amber": { "$value": "#F2B233", "$type": "color", "$description": "warn / delayed / degraded" }
    }
  },
  "type": {
    "family": {
      "ui":   { "$value": "Inter, system-ui, sans-serif",          "$type": "fontFamily" },
      "mono": { "$value": "'JetBrains Mono', ui-monospace, monospace", "$type": "fontFamily" }
    },
    "role": {
      "display":  { "$value": { "fontFamily": "{type.family.mono}", "fontWeight": 800, "fontSize": "56px", "lineHeight": "1.00", "letterSpacing": "-0.030em" }, "$type": "typography" },
      "h1":       { "$value": { "fontFamily": "{type.family.mono}", "fontWeight": 700, "fontSize": "32px", "lineHeight": "1.15", "letterSpacing": "-0.015em" }, "$type": "typography" },
      "h2":       { "$value": { "fontFamily": "{type.family.mono}", "fontWeight": 600, "fontSize": "22px", "lineHeight": "1.20", "letterSpacing": "0" }, "$type": "typography" },
      "body":     { "$value": { "fontFamily": "{type.family.ui}",   "fontWeight": 400, "fontSize": "16px", "lineHeight": "1.55", "letterSpacing": "0" }, "$type": "typography" },
      "ui":       { "$value": { "fontFamily": "{type.family.ui}",   "fontWeight": 500, "fontSize": "13px", "lineHeight": "1.40", "letterSpacing": "0" }, "$type": "typography" },
      "code":     { "$value": { "fontFamily": "{type.family.mono}", "fontWeight": 500, "fontSize": "13px", "lineHeight": "1.50", "letterSpacing": "0" }, "$type": "typography" }
    }
  },
  "space": {
    "s-1": { "$value": "4px",  "$type": "dimension" },
    "s-2": { "$value": "8px",  "$type": "dimension" },
    "s-3": { "$value": "12px", "$type": "dimension" },
    "s-4": { "$value": "16px", "$type": "dimension" },
    "s-5": { "$value": "24px", "$type": "dimension" },
    "s-6": { "$value": "32px", "$type": "dimension" },
    "s-7": { "$value": "48px", "$type": "dimension" },
    "s-8": { "$value": "64px", "$type": "dimension" }
  }
}
